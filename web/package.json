{
  "name": "smart-study-desk-monitor-web",
  "version": "1.0.0",
  "description": "Dashboard web pour Smart Study Desk Monitor - Projet IoT",
  "main": "src/app.js",
  "scripts": {
    "start": "live-server public --port=8080 --open=/index.html",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.js",
    "lint:fix": "eslint src/**/*.js --fix",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "format:check": "prettier --check \"src/**/*.{js,css,html}\"",
    "deploy": "firebase deploy",
    "serve": "firebase serve"
  },
  "keywords": [
    "iot",
    "firebase",
    "esp32",
    "dashboard",
    "sensors",
    "realtime"
  ],
  "author": "Projet Académique IoT - 3 Étudiants",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@babel/preset-env": "^7.23.0",
    "babel-loader": "^9.1.3",
    "css-loader": "^6.8.1",
    "eslint": "^8.50.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.28.1",
    "html-webpack-plugin": "^5.5.3",
    "jest": "^29.7.0",
    "live-server": "^1.2.2",
    "prettier": "^3.0.3",
    "style-loader": "^3.3.3",
    "webpack": "^5.88.2",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  },
  "dependencies": {
    "firebase": "^10.8.0",
    "chart.js": "^4.4.0",
    "bootstrap": "^5.3.2"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
